set -euo pipefail

GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || true)

if [[ -z "${GIT_DIR}" ]]; then
    echo "ERROR: Folder '${PWD}' is not part of a working git tree." >&2
    exit 1
fi

# Use Git's native modern configuration to proxy hooks directly to the scripts folder!
# Hooks evaluate relative paths relative to the root of the working tree.
git config core.hooksPath "scripts/hooks"

echo "✅ Git hooks configured successfully to securely proxy to 'scripts/hooks'."
